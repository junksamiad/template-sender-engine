{
  "name": "template_variables",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "variables": {
        "type": "object",
        "description": "Numbered variables for WhatsApp template placeholders",
        "patternProperties": {
          "^[0-9]+$": {
            "type": "string",
            "description": "A template variable value"
          }
        },
        "minProperties": 1,
        "additionalProperties": false
      }
    },
    "required": ["variables"],
    "additionalProperties": false
  }
} 